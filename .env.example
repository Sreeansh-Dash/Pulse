# Database
# Local Dev (SQLite): sqlite+aiosqlite:///./pulse.db
# Prod (Postgres): postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./pulse.db

# Redis Job Queue & Pub/Sub
REDIS_URL=redis://localhost:6379/0

# Alerting (Optional)
DISCORD_WEBHOOK_URL=

# Default check interval in seconds
CHECK_INTERVAL_SECONDS=120
